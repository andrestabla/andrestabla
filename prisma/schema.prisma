generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id       String @id @default(uuid())
  username String @unique
  password String
}

enum ConsentDecision {
  accepted
  declined
}

enum AnalyticsEventType {
  page_view
  section_view
  assistant_question
}

model SiteSettings {
  id           String @id @default("global")
  title        String
  description  String?
  globalStyles String // JSON stringified for global variables (fonts, main colors)
}

model Page {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String?
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  blocks      Block[]
}

model Block {
  id        String   @id @default(uuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      String   // e.g., 'hero', 'timeline', 'bento', 'richtext', 'spacer', 'grid'
  data      String   // JSON stringified payload specific to the block type
  styles    String?  // JSON stringified styling overrides (padding, background, grid config)
  order     Int      @default(0)
  
  // Advanced Layout: Hierarchy for Nesting (e.g. Columns inside a Grid)
  parentId  String?
  parent    Block?   @relation("BlockChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  Block[]  @relation("BlockChildren")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageId])
  @@index([parentId])
}

model ConsentRecord {
  id            String          @id @default(cuid())
  decision      ConsentDecision
  policyVersion String
  path          String?
  country       String?
  region        String?
  city          String?
  latitude      Float?
  longitude     Float?
  userAgent     String?
  createdAt     DateTime        @default(now())

  @@index([decision, createdAt])
  @@index([country, region, city])
}

model AnalyticsEvent {
  id            String             @id @default(cuid())
  eventType     AnalyticsEventType
  pagePath      String?
  sectionId     String?
  sectionLabel  String?
  question      String?
  policyVersion String?
  country       String?
  region        String?
  city          String?
  latitude      Float?
  longitude     Float?
  userAgent     String?
  createdAt     DateTime           @default(now())

  @@index([eventType, createdAt])
  @@index([pagePath, eventType])
  @@index([country, region, city])
}
